---
---

<section id="hero" class="min-h-screen flex items-center pt-20 pb-16 px-6">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <p class="text-sm text-secondary mb-4 fade-in">Madrid · España</p>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium text-primary mb-2 fade-in stagger-1">
          Diego De Asís Ruiz
        </h1>

        <p class="text-lg md:text-xl text-secondary mb-6 fade-in stagger-2">
          Salesforce Product Owner · CRM Consultant · Product & Design Thinking
        </p>

        <p class="text-xl md:text-2xl text-primary max-w-lg mb-6 fade-in stagger-3">
          6+ años construyendo plataformas Salesforce para organizaciones internacionales.
        </p>

        

        <div class="flex flex-wrap gap-4 fade-in stagger-5">
          <a
            href="#work"
            class="inline-flex items-center px-6 py-3 bg-primary text-white rounded-full font-medium hover:opacity-90 transition-opacity"
          >
            Ver experiencia ↓
          </a>
          <a
            href="#contact"
            class="inline-flex items-center px-6 py-3 border border-primary text-primary rounded-full font-medium hover:bg-primary hover:text-white transition-colors"
          >
            Contactar →
          </a>
        </div>

        <p class="text-sm text-secondary mt-8 fade-in stagger-5">
          Madrid · Español/English · Respuesta &lt;24h
        </p>
      </div>

      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-64 h-80 md:w-80 md:h-96 lg:w-96 lg:h-[500px] rounded-lg overflow-hidden fade-in stagger-2">
          <img 
            src="/images/FotoDiego.jpg" 
            alt="Diego De Asís Ruiz" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <p class="text-white/90 text-sm italic font-light leading-relaxed">
              La disciplina con la que trabajo nació combinando proyectos Salesforce con la exigencias del deporte universitario.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>