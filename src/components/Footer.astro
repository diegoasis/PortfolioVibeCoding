---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 px-6 bg-white border-t border-gray-100">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-sm text-secondary">
      © {currentYear} Diego De Asís Ruiz
    </div>

    <div class="flex items-center gap-2">
      <span class="text-sm text-secondary">Technology should feel invisible.</span>
      <span class="text-sm text-secondary">The best products usually are.</span>
    </div>

    <div class="flex gap-6 text-sm">
      <a href="#hero" class="text-secondary hover:text-primary transition-colors">Top</a>
    </div>
  </div>
</footer>