<script>
  import { animate, inView } from 'motion';

  const fadeInUp = {
    opacity: [0, 1],
    y: [30, 0],
  };

  const fadeIn = {
    opacity: [0, 1],
  };

  const options = {
    duration: 0.6,
    easing: [0.16, 1, 0.3, 1],
  };

  document.querySelectorAll('.fade-in').forEach((el) => {
    animate(el, fadeInUp, { duration: 0.6, delay: 0.1, easing: [0.16, 1, 0.3, 1] });
  });

  inView('.animate-on-scroll', ({ target }) => {
    animate(
      target,
      { opacity: [0, 1], y: [40, 0] },
      { duration: 0.7, easing: [0.16, 1, 0.3, 1] }
    );
  });

  inView('.animate-stagger', ({ target }) => {
    const children = target.querySelectorAll('.stagger-item');
    children.forEach((child, i) => {
      animate(
        child,
        { opacity: [0, 1], y: [30, 0] },
        { duration: 0.5, delay: i * 0.1, easing: [0.16, 1, 0.3, 1] }
      );
    });
  });
</script>