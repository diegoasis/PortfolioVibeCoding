---
const projects = [
  {
    title: 'International CRM Rollout',
    context: 'Gestión de la evolución Salesforce para mercados internacionales.',
    challenge: 'Unificar necesidades comerciales y operativas de múltiples países bajo una plataforma CRM común.',
    solution: 'Definición de roadmap, priorización funcional y coordinación entre negocio y tecnología.',
    outcome: 'Evolución coordinada de la plataforma CRM en distintos mercados internacionales.',
    scale: '+500 usuarios comerciales · 5 mercados internacionales',
    tech: 'Salesforce CRM · Service Cloud · Jira · Scrum · Product Ownership',
  },
  {
    title: 'International Payment Tracker',
    context: 'Proyecto bancario enterprise para una de las mayores entidades financieras de España.',
    challenge: 'Implementar trazabilidad internacional de pagos integrada con sistemas legacy y operativas bancarias complejas.',
    solution: 'Integración Salesforce + APIs + middleware empresarial para seguimiento de pagos internacionales en tiempo real.',
    outcome: 'Segundo banco en España en implementar esta funcionalidad.',
    scale: 'Segundo banco en España · +X operaciones internacionales monitorizadas',
    tech: 'Salesforce · REST APIs · Apex · Jenkins',
  },
];
---

<section id="work" class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <p class="text-sm text-secondary mb-4">Proyectos</p>
    <h2 class="text-3xl md:text-4xl font-medium text-primary mb-16">Proyectos estratégicos</h2>

    <div class="grid md:grid-cols-2 gap-12">
      {projects.map((project, index) => (
        <article>
          <div class="border-t-2 border-accent/30 pt-6">
            <p class="text-xs text-secondary uppercase tracking-wider mb-3">Proyecto {index + 1}</p>
            <h3 class="text-xl md:text-2xl font-medium text-primary mb-4">
              {project.title}
            </h3>

            <div class="space-y-4 mb-6">
              <div>
                <p class="text-xs text-secondary uppercase tracking-wider mb-1">Contexto</p>
                <p class="text-sm text-primary">{project.context}</p>
              </div>
              <div>
                <p class="text-xs text-secondary uppercase tracking-wider mb-1">Challenge</p>
                <p class="text-sm text-primary">{project.challenge}</p>
              </div>
              <div>
                <p class="text-xs text-secondary uppercase tracking-wider mb-1">Solución</p>
                <p class="text-sm text-primary">{project.solution}</p>
              </div>
              <div>
                <p class="text-xs text-secondary uppercase tracking-wider mb-1">Outcome</p>
                <p class="text-sm text-primary">{project.outcome}</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-2 mb-4">
              <span class="text-xs text-secondary">{project.scale}</span>
            </div>

            <p class="text-xs text-accent border border-accent/30 bg-accent/5 rounded px-3 py-2 inline-block">
              {project.tech}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>