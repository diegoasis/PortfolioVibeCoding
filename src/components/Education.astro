---
const education = [
  {
    institution: 'Universidad Pontificia de Comillas',
    degree: 'Grado en Ingeniería en Tecnologías Industriales',
    period: '2014 - 2018',
  },
  {
    institution: 'University of Nevada, Las Vegas (UNLV)',
    degree: 'NCAA Division I - Athletics (Swimming)',
    period: '2015 - 2017',
  },
];

const leadership = [
  'Capitán del equipo de natación NCAA Division I',
  'Representación internacional en competencias universitarias',
  'Desarrollo de mentalidad de alto rendimiento y disciplina',
];
---

<section id="education" class="py-24 px-6 bg-subtle">
  <div class="max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <p class="text-sm text-secondary mb-4">Education</p>
        <h2 class="text-3xl md:text-4xl font-medium text-primary mb-8">Formación académica</h2>

        <div class="space-y-8">
          {education.map(edu => (
            <div class="border-l-2 border-gray-200 pl-6">
              <p class="text-xs text-secondary mb-1">{edu.period}</p>
              <h3 class="text-lg font-medium text-primary">{edu.degree}</h3>
              <p class="text-sm text-secondary">{edu.institution}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <p class="text-sm text-secondary mb-4">Leadership</p>
        <h2 class="text-3xl md:text-4xl font-medium text-primary mb-8">Experiencia atlética</h2>

        <div class="bg-white p-8 rounded-lg">
          <p class="text-lg text-primary mb-6 leading-relaxed">
            La combinación entre ingeniería, diseño y deporte competitivo define cómo lidero proyectos y equipos.
          </p>

          <ul class="space-y-4">
            {leadership.map(item => (
              <li class="flex items-start gap-3 text-sm text-primary">
                <span class="w-2 h-2 rounded-full bg-primary mt-2 flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>