---
const socialLinks = [
  { label: 'LinkedIn', url: 'https://linkedin.com/in/diegodeasis' },
  { label: 'Email', url: 'mailto:diego.deasis@example.com' },
];
---

<section id="contact" class="py-24 px-6 bg-primary text-white">
  <div class="max-w-6xl mx-auto text-center">
    <p class="text-sm text-white/60 mb-4">Contact</p>
    <h2 class="text-3xl md:text-4xl font-medium mb-8">Trabajemos juntos</h2>

    <p class="text-white/80 max-w-xl mx-auto mb-12">
      Siempre abierto a explorar nuevas oportunidades internacionales y proyectos de consultoría estratégica.
    </p>

    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a
        href="mailto:diego.deasis@example.com"
        class="inline-flex items-center px-8 py-4 bg-white text-primary rounded-full font-medium hover:bg-white/90 transition-colors"
      >
        Contactar por email
      </a>
      <a
        href="https://linkedin.com/in/diegodeasis"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-8 py-4 border border-white text-white rounded-full font-medium hover:bg-white/10 transition-colors"
      >
        LinkedIn →
      </a>
    </div>

    <div class="flex justify-center gap-8 text-sm text-white/60">
      {socialLinks.map(link => (
        <a
          href={link.url}
          target={link.label === 'LinkedIn' ? '_blank' : undefined}
          rel={link.label === 'LinkedIn' ? 'noopener noreferrer' : undefined}
          class="hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>