---
const companies = [
  { name: 'Suntory', logo: '/logos/Suntory_Global_Spirits_logo.svg' },
  { name: 'Deloitte', logo: '/logos/deloitte-2.svg' },
  { name: 'Accenture', logo: '/logos/accenture-6.svg' },
];
---

<section class="py-16 px-6 bg-white border-y border-accent/20">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-wrap justify-center items-center gap-16 md:gap-24">
      {companies.map(company => (
        <img 
          src={company.logo} 
          alt={company.name} 
          class="h-10 md:h-12 w-auto object-contain"
        />
      ))}
    </div>
  </div>
</section>